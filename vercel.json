{
  "rewrites": [
    { "source": "/api/auth/:path*", "destination": "/api/auth/:path*" },
    { "source": "/api/admin/:path*", "destination": "/api/admin/:path*" },
    { "source": "/api/chat", "destination": "/api/chat/index" },
    { "source": "/(.*)", "destination": "/public/index.html" }
  ],
  "functions": {
    "api/**/*.js": { "maxDuration": 30 }
  }
}
